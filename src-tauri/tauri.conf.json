{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashnote",
  "version": "2.0.0",
  "identifier": "com.flashnote.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "inbox",
        "create": false,
        "title": "Flashnote · 稍后看",
        "url": "index.html?window=inbox",
        "width": 960,
        "height": 680,
        "minWidth": 700,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "capture",
        "create": false,
        "title": "快速记录",
        "url": "index.html?window=capture",
        "width": 432,
        "height": 64,
        "minWidth": 56,
        "maxWidth": 680,
        "minHeight": 40,
        "maxHeight": 64,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "fullscreen": false
      },
      {
        "label": "focus",
        "create": false,
        "title": "今日专注",
        "url": "index.html?window=focus",
        "width": 360,
        "height": 340,
        "minWidth": 360,
        "maxWidth": 360,
        "minHeight": 68,
        "maxHeight": 340,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "先收下来，别打断当下。",
    "longDescription": "一个本地优先的灵感收件箱、长期计划与今日专注工具。",
    "category": "Productivity",
    "copyright": "Copyright © 2026 Flashnote contributors",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 190
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
